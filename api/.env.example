# ── Airtable ───────────────────────────────────────────────
# Full read/write on PUB Legal base (appUInS3SOfPul1jr)
AIRTABLE_PAT_LEGAL=pat_xxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_LEGAL=appUInS3SOfPul1jr

# Read-only on PUB Development base (appw92pCC1jrY5CNv), scoped to Pipeline table
AIRTABLE_PAT_DEVELOPMENT=pat_xxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_DEVELOPMENT=appw92pCC1jrY5CNv

# ── Auth ───────────────────────────────────────────────────
# 32+ byte random string. Generate: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string

# Cookie domain (shared between portal and employee app if same root)
COOKIE_DOMAIN=.popupbagels.com

# ── Email (Postmark) ───────────────────────────────────────
POSTMARK_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EMAIL_FROM=legal@popupbagels.com
EMAIL_FROM_NAME=PUB Legal Portal

# ── URLs ───────────────────────────────────────────────────
FRONTEND_URL_LEGAL=https://legal.popupbagels.com
FRONTEND_URL_PORTAL=https://portal.popupbagels.com

# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
